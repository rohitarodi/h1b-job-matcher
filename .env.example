# H1B Job Matcher + Application Tracker
# Copy this to .env and fill in your values

# Path to your Google OAuth token (for Gmail tracker)
# Generate this by running: python3 auth.py
# in your openclaw-calendar directory
GOOGLE_TOKEN_PATH=~/openclaw-calendar/token.json

# The Flask app endpoint (default: localhost:5000)
TRACKER_API=http://localhost:5000/api/applications
